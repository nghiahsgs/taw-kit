{
  "note": "taw-kit defaults for Vietnamese non-dev users. Hook paths resolve via $HOME/.claude/hooks/.",
  "env": {
    "TAW_NO_AUTOCOMMIT": "0",
    "TAW_KIT_VERSION": "{{TAW_KIT_VERSION}}"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-start-context.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/post-tool-auto-commit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/permission-classifier.sh"
          }
        ]
      }
    ]
  }
}
