#!/usr/bin/env bash
# tawkit — main entry point
# Usage:
#   tawkit install | update | uninstall | doctor | new <preset> | --help | --version

set -eu

# Resolve TAW_ROOT: prefer $TAW_ROOT env, then $HOME/.taw-kit, then script parent
if [ -n "${TAW_ROOT:-}" ] && [ -f "$TAW_ROOT/scripts/tawkit" ]; then
  :
elif [ -f "$HOME/.taw-kit/scripts/tawkit" ]; then
  TAW_ROOT="$HOME/.taw-kit"
else
  # Assume we're running from a clone: /path/to/taw-kit/scripts/tawkit
  TAW_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
fi
export TAW_ROOT

# shellcheck source=lib/log.sh
. "$TAW_ROOT/scripts/lib/log.sh"

show_help() {
  cat <<'EOF'
tawkit — vibe-coding toolkit for non-developers

USAGE:
  tawkit install          Install all skills, agents, and hooks into ~/.claude/
  tawkit update           Update the kit to the latest version
  tawkit uninstall        Remove taw-kit (your personal skills stay intact)
  tawkit uninstall --full Remove everything, including the repo clone at ~/.taw-kit/
  tawkit doctor           Check that your machine has everything set up
  tawkit new <preset>     Scaffold a new project from a preset
  tawkit --help           Show this help
  tawkit --version        Show the installed version

EXAMPLES:
  tawkit install                   # first-time setup
  tawkit doctor                    # when something feels off
  tawkit new shop-online           # scaffold an online shop fast
  tawkit update                    # when a new version ships

Full docs: https://taw-kit.dev/docs
EOF
}

case "${1:-}" in
  install)
    shift
    exec bash "$TAW_ROOT/scripts/install.sh" "$@"
    ;;
  update)
    shift
    exec bash "$TAW_ROOT/scripts/update.sh" "$@"
    ;;
  uninstall)
    shift
    exec bash "$TAW_ROOT/scripts/uninstall.sh" "$@"
    ;;
  doctor)
    shift
    exec bash "$TAW_ROOT/scripts/doctor.sh" "$@"
    ;;
  new)
    shift
    if [ $# -eq 0 ]; then
      err "missing preset name. Example: tawkit new shop-online"
      exit 1
    fi
    preset="$1"
    if [ ! -f "$TAW_ROOT/presets/$preset.md" ]; then
      err "preset not found: $preset"
      info "list available presets: ls $TAW_ROOT/presets/"
      exit 1
    fi
    # Hand off to Claude Code's /taw-new skill
    if ! command -v claude >/dev/null 2>&1; then
      err "Claude Code is not installed. See: https://docs.claude.com/claude-code"
      exit 3
    fi
    exec claude --skill taw-new --arg "$preset"
    ;;
  --help|-h|help)
    show_help
    ;;
  --version|-v|version)
    cat "$TAW_ROOT/VERSION"
    ;;
  '')
    show_help
    ;;
  *)
    err "unknown command: $1"
    show_help
    exit 1
    ;;
esac
